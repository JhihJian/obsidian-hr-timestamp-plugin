{
  "name": "obsidian-hr-timestamp-plugin",
  "version": "0.1.0",
  "description": "Convert long dashed divider input into a standard horizontal rule with a timestamp in Obsidian.",
  "main": "main.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs",
    "copy-output": "node esbuild.config.mjs --production && node scripts/copy-output.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown"
  ],
  "author": "JhihJian",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^25.9.3",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "happy-dom": "^20.10.2",
    "obsidian": "1.13.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
